# =============================================================================
# Memos — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Railway automatically injects DATABASE_URL when you provision PostgreSQL.
# =============================================================================

# ---------------------------------------------------------------------------
# Database Configuration
# ---------------------------------------------------------------------------
# Memos supports SQLite (default), PostgreSQL, and MySQL.
# For Railway, use the PostgreSQL addon — Railway injects DATABASE_URL.
# The build entrypoint automatically reads MEMOS_DSN.
MEMOS_DSN="postgres://${PGUSER}:${PGPASSWORD}@${PGHOST}:${PGPORT}/${PGDATABASE}?sslmode=require"

# Alternatively, set MEMOS_DSN directly (overrides the DATABASE_URL mapping):
# MEMOS_DSN=postgres://user:pass@host:5432/memos?sslmode=require

# For SQLite (default, no database addon needed):
# MEMOS_DSN=

# ---------------------------------------------------------------------------
# Server Configuration
# ---------------------------------------------------------------------------

# Port to listen on (default: 5230)
# Railway maps this via PORT but Memos listens on MEMOS_PORT
MEMOS_PORT=5230

# Timezone (default: UTC)
TZ=UTC

# Data directory (default: /var/opt/memos)
# MEMOS_DATA_DIR=/var/opt/memos

# Log level: debug, info, warn, error (default: info)
# MEMOS_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Admin Account (first-time setup — set before initial deploy)
# ---------------------------------------------------------------------------
# On first launch, Memos creates an admin account.
# You can pre-configure credentials via environment variables:
# MEMOS_ADMIN_EMAIL=admin@example.com
# MEMOS_ADMIN_PASSWORD=your-secure-password-here

# ---------------------------------------------------------------------------
# Advanced: Docker Secret Support
# ---------------------------------------------------------------------------
# Memos' entrypoint supports Docker secrets via _FILE suffix.
# Set MEMOS_DSN_FILE to a file path containing the DSN instead:
# MEMOS_DSN_FILE=/run/secrets/memos_dsn
